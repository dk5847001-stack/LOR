<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= lor.lorId %> - Letter of Recommendation</title>
    <style>
      @page {
        size: A4;
        margin: 0;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: #172033;
        background: #eef4fa;
        font-family: "Times New Roman", Georgia, serif;
      }

      .page {
        position: relative;
        width: 210mm;
        min-height: 297mm;
        padding: 14mm;
        background: #ffffff;
        overflow: hidden;
      }

      .page::before {
        content: "";
        position: absolute;
        inset: 7mm;
        border: 2.2px solid #0a4f82;
      }

      .page::after {
        content: "";
        position: absolute;
        inset: 10mm;
        border: 1px solid #b8d9ef;
      }

      .corner {
        position: absolute;
        z-index: 0;
        width: 35mm;
        height: 35mm;
        border-color: #b88a2e;
      }

      .corner.tl {
        top: 9mm;
        left: 9mm;
        border-top: 2px solid;
        border-left: 2px solid;
      }

      .corner.tr {
        top: 9mm;
        right: 9mm;
        border-top: 2px solid;
        border-right: 2px solid;
      }

      .corner.bl {
        bottom: 9mm;
        left: 9mm;
        border-bottom: 2px solid;
        border-left: 2px solid;
      }

      .corner.br {
        right: 9mm;
        bottom: 9mm;
        border-right: 2px solid;
        border-bottom: 2px solid;
      }

      .watermark {
        position: absolute;
        top: 103mm;
        left: 50%;
        width: 92mm;
        opacity: 0.04;
        transform: translateX(-50%);
      }

      .content {
        position: relative;
        z-index: 1;
        min-height: 269mm;
        padding: 4mm 5mm 0;
      }

      .topbar {
        display: grid;
        grid-template-columns: 60mm 1fr;
        gap: 14mm;
        align-items: center;
        padding: 0 0 10px;
        border-bottom: 3px double #b8d9ef;
      }

      .logo {
        width: 58mm;
        height: 26mm;
        object-fit: contain;
        object-position: left center;
      }

      .company {
        text-align: right;
        font-family: Arial, sans-serif;
      }

      .company h1 {
        margin: 0;
        color: #081527;
        font-size: 29px;
        font-weight: 800;
        letter-spacing: 0;
      }

      .company p {
        margin: 4px 0 0;
        color: #516174;
        font-size: 12px;
      }

      .company .tag {
        display: inline-block;
        margin-top: 7px;
        padding: 4px 9px;
        color: #0a4f82;
        border: 1px solid #b8d9ef;
        border-radius: 999px;
        background: #f4f9fd;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
      }

      .title {
        margin: 18px 0 12px;
        text-align: center;
      }

      .title .kicker {
        margin: 0 0 6px;
        color: #0f7fd1;
        font-family: Arial, sans-serif;
        font-size: 10.5px;
        font-weight: 800;
        text-transform: uppercase;
      }

      .title h2 {
        margin: 0;
        color: #081527;
        font-family: Arial, sans-serif;
        font-size: 30px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0;
      }

      .title-rule {
        width: 72mm;
        height: 3px;
        margin: 8px auto 0;
        background: linear-gradient(90deg, #b88a2e, #0f7fd1, #b88a2e);
      }

      .meta {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        margin: 14px 0 17px;
        border: 1px solid #cfe2f0;
        background: #f8fbfe;
        font-family: Arial, sans-serif;
      }

      .meta div {
        padding: 9px 11px;
        border-right: 1px solid #dceaf5;
      }

      .meta div:last-child {
        border-right: 0;
      }

      .meta span {
        display: block;
        color: #667085;
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
      }

      .meta strong {
        display: block;
        margin-top: 3px;
        color: #081527;
        font-size: 12px;
      }

      .letter {
        font-size: 14.7px;
        line-height: 1.55;
        text-align: justify;
      }

      .letter p {
        margin: 0 0 10px;
      }

      .student-name {
        color: #081527;
        font-weight: 700;
      }

      .credential-box {
        margin: 13px 0 14px;
        padding: 12px;
        border: 1px solid #cfe2f0;
        border-left: 5px solid #0f7fd1;
        background: #fbfdff;
      }

      .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 9px;
        font-family: Arial, sans-serif;
        font-size: 11.5px;
      }

      .info-item {
        min-height: 42px;
        padding: 8px 9px;
        border: 1px solid #e0edf6;
        background: #ffffff;
      }

      .info-item.full {
        grid-column: 1 / -1;
      }

      .info-item span {
        display: block;
        color: #667085;
        font-size: 9.5px;
        font-weight: 800;
        text-transform: uppercase;
      }

      .info-item strong {
        display: block;
        margin-top: 3px;
        color: #172033;
        font-size: 12px;
      }

      .closing {
        margin-top: 8px;
      }

      .signature-row {
        display: grid;
        grid-template-columns: 1fr 36mm 38mm;
        gap: 11mm;
        align-items: end;
        margin-top: 15px;
      }

      .signature {
        width: 52mm;
        height: 21mm;
        object-fit: contain;
        object-position: left center;
      }

      .sign-line {
        width: 58mm;
        border-top: 1px solid #667085;
      }

      .sign-name {
        margin-top: 5px;
        color: #081527;
        font-family: Arial, sans-serif;
        font-size: 12.3px;
        font-weight: 800;
      }

      .sign-role,
      .verify-text,
      .note {
        color: #516174;
        font-family: Arial, sans-serif;
        font-size: 10px;
      }

      .seal {
        width: 33mm;
        height: 33mm;
        object-fit: contain;
      }

      .qr-card {
        padding: 7px;
        border: 1px solid #cfe2f0;
        background: #ffffff;
        text-align: center;
      }

      .qr {
        width: 27mm;
        height: 27mm;
      }

      .verify-text {
        margin-top: 4px;
        word-break: break-all;
      }

      .footer-note {
        position: absolute;
        right: 19mm;
        bottom: 12mm;
        left: 19mm;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding-top: 7px;
        border-top: 1px solid #dceaf5;
        font-family: Arial, sans-serif;
        font-size: 10px;
        color: #516174;
      }

      .footer-note strong {
        color: #081527;
      }

      .center {
        text-align: center;
      }
    </style>
  </head>
  <body>
    <section class="page">
      <div class="corner tl"></div>
      <div class="corner tr"></div>
      <div class="corner bl"></div>
      <div class="corner br"></div>
      <img class="watermark" src="<%= sealData %>" alt="">

      <div class="content">
        <header class="topbar">
          <img class="logo" src="<%= logoData %>" alt="InternovaTech logo">
          <div class="company">
            <h1>InternovaTech</h1>
            <p>Professional Internship & Training Platform</p>
            <div class="tag">Official Recommendation Document</div>
          </div>
        </header>

        <div class="title">
          <p class="kicker">Formal Endorsement</p>
          <h2>Letter of Recommendation</h2>
          <div class="title-rule"></div>
        </div>

        <section class="meta">
          <div>
            <span>Issue Date</span>
            <strong><%= formatDate(lor.issueDate) %></strong>
          </div>
          <div>
            <span>Document ID</span>
            <strong><%= lor.lorId %></strong>
          </div>
          <div>
            <span>Status</span>
            <strong>Digitally Verifiable</strong>
          </div>
        </section>

        <main class="letter">
          <p><strong>To whom it may concern,</strong></p>
          <p>
            This letter is issued by <strong>InternovaTech</strong> in recognition of the internship performance of
            <span class="student-name"><%= lor.studentName %></span>. The candidate completed an internship in
            <strong><%= lor.internshipDomain %></strong> and contributed to the project titled
            <strong><%= lor.projectName %></strong>.
          </p>

          <section class="credential-box">
            <div class="info-grid">
              <div class="info-item">
                <span>Candidate</span>
                <strong><%= lor.studentName %></strong>
              </div>
              <div class="info-item">
                <span>Internship Domain</span>
                <strong><%= lor.internshipDomain %></strong>
              </div>
              <div class="info-item">
                <span>Duration</span>
                <strong><%= lor.durationText %></strong>
              </div>
              <div class="info-item">
                <span>Period</span>
                <strong><%= formatDate(lor.startDate) %> to <%= formatDate(lor.endDate) %></strong>
              </div>
              <div class="info-item">
                <span>Performance</span>
                <strong><%= lor.performance %></strong>
              </div>
              <div class="info-item">
                <span>Company</span>
                <strong><%= lor.companyName || "InternovaTech" %></strong>
              </div>
              <div class="info-item full">
                <span>Skills Demonstrated</span>
                <strong><%= skillsText || "Professional conduct, discipline, learning attitude, and task ownership" %></strong>
              </div>
            </div>
          </section>

          <p><%= letterBody %></p>
          <p class="closing">
            Throughout the internship period, <span class="student-name"><%= lor.studentName %></span> maintained a responsible work ethic,
            communicated professionally, and showed a constructive approach toward assigned work. Based on the performance observed,
            we are pleased to recommend the candidate for future academic, internship, and professional opportunities.
          </p>
        </main>

        <section class="signature-row">
          <div>
            <img class="signature" src="<%= signatureData %>" alt="Authorized signature">
            <div class="sign-line"></div>
            <div class="sign-name"><%= lor.authorizedPersonName %></div>
            <div class="sign-role"><%= lor.authorizedPersonDesignation %>, InternovaTech</div>
          </div>
          <div class="center">
            <img class="seal" src="<%= sealData %>" alt="InternovaTech seal">
            <div class="note">Official Seal</div>
          </div>
          <div class="qr-card">
            <img class="qr" src="<%= qrCodeData %>" alt="Verification QR code">
            <div class="verify-text"><%= lor.verificationUrl %></div>
          </div>
        </section>
      </div>

      <footer class="footer-note">
        <span>This document can be verified online using the QR code or LOR ID.</span>
        <strong><%= lor.lorId %></strong>
      </footer>
    </section>
  </body>
</html>
